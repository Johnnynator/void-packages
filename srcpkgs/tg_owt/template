	makedepends+=" musl-legacy-compat"
fi

if [ "$XBPS_TARGET_ENDIAN" = "be" ]; then
	broken="#errors in audio data parsers"
fi

post_extract() {
	bsdtar xzf ${XBPS_SRCDISTDIR}/${pkgname}-${version}/${_libyuv_commit}.tar.gz -C ${wrksrc}/src/third_party/libyuv
}
